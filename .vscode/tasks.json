{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "shell",
            "label": "Compilar C++ (Todos los archivos)",
            "command": "g++",
            "args": [
                "-g",
                "${workspaceFolder}/*.cpp",
                "${workspaceFolder}/*.cc",
                "-o",
                "${workspaceFolder}/output/main.exe"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "detail": "Compila todos los archivos .cpp y .cc de la carpeta actual en output/main.exe"
        },
        {
            "type": "shell",
            "label": "Compilar y Ejecutar C++",
            "command": "powershell",
            "args": [
                "-Command",
                "g++ -g (Get-ChildItem -Path . -Include *.cpp,*.cc -Recurse | Select-Object -ExpandProperty FullName) -o output/main.exe; if ($?) { .\\output\\main.exe }"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": "test",
            "detail": "Compila y ejecuta el programa directamente"
        },
        {
            "type": "cppbuild",
            "label": "C/C++: gcc.exe build active file",
            "command": "C:/mingw64/bin/gcc.exe",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "${file}",
                "-o",
                "${fileDirname}\\${fileBasenameNoExtension}.exe",
                ""
            ],
            "options": {
                "cwd": "C:/mingw64/bin"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Task generated by Debugger."
        }
    ]
}